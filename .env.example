# Local dataset paths (do not commit actual .env)
TRAIN_PATH=TRAIN.csv
TEST_PATH=TEST.csv

# Fast smoke test mode (recommended for quick sanity check)
# When true: fewer seeds/folds and smaller RF to run quickly
FAST_SMOKE_TEST=true

# Cross-validation configuration
# Comma-separated list of seeds
SEEDS=42
# Number of folds
N_SPLITS=3

# pipeline toggles
ENABLE_ADVERSARIAL_VALIDATION=false
ENABLE_CALIBRATION=true
ENABLE_PSEUDO_LABELING_TOP1=false

# Advanced modules (optional; require requirements-full.txt for best results)
ENABLE_WEIGHT_OPTIMIZATION=true
WEIGHT_SEARCH_ITERS=250
ENABLE_CV_STABILITY_REPORT=true

# Automated hyperparameter tuning (Optuna)
ENABLE_OPTUNA=false

# Interpretability (SHAP)
ENABLE_SHAP=false
ENABLE_SHAP_REFINEMENT=false
SHAP_TOP_N=40

# Pseudo labeling thresholds (used only if enabled)
PSEUDO_POS_TH=0.95
PSEUDO_NEG_TH=0.05

# Weighted ensemble coefficients
XGB_WEIGHT=0.35
LGBM_WEIGHT=0.30
RF_WEIGHT=0.15
TABNET_WEIGHT=0.10
META_WEIGHT=0.10
